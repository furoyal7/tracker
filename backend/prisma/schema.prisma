generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  passcode       String?
  role           UserRole        @default(USER)
  isOnline       Boolean         @default(false)
  lastSeen       DateTime        @default(now())
  preferredLanguage String       @default("en")
  age            Int?
  avatarUrl      String?
  bio            String?         @db.Text
  name           String?         @db.Text
  username       String?         @unique
  phone          String?         @unique
  businessName   String?         @db.Text
  businessType   String?         @db.Text
  address        String?         @db.Text
  isVerified     Boolean         @default(false)
  status         UserStatus      @default(ACTIVE)
  sessions       Session[]
  activityLogs   ActivityLog[]
  debts          Debt[]
  exchangeOrders ExchangeOrder[]
  products       Product[]
  transactions   Transaction[]
  sales          Sale[]
  conversations  Conversation[]  @relation("ConversationParticipants")
  messages       Message[]       @relation("MessageSender")
  seenMessages   Message[]       @relation("MessageSeenBy")
  offlineActions OfflineAction[]
}

model Transaction {
  id        String          @id @default(uuid())
  amount    Float
  category  String          @db.Text
  date      DateTime        @default(now())
  note      String?         @db.Text
  userId    String
  type      TransactionType
  productId String?
  quantity  Int?            @default(1)
  paymentMethod String?     @db.Text
  partyName     String?     @db.Text
  reference     String?
  product   Product?        @relation(fields: [productId], references: [id])
  user      User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
  @@index([type])
  @@index([category])
}

model Product {
  id           String        @id @default(uuid())
  name         String        @db.Text
  quantity     Int           @default(0)
  costPrice    Float
  sellingPrice Float
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
  saleItems    SaleItem[]

  @@index([userId])
  @@index([createdAt])
}

model Debt {
  id              String     @id @default(uuid())
  dueDate         DateTime
  createdAt       DateTime   @default(now())
  name            String     @db.Text
  remainingAmount Float
  totalAmount     Float
  type            DebtType
  updatedAt       DateTime   @updatedAt
  userId          String
  status          DebtStatus @default(UNPAID)
  phone           String?
  user            User       @relation(fields: [userId], references: [id])
  payments        Payment[]

  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

model Payment {
  id     String   @id @default(uuid())
  amount Float
  date   DateTime @default(now())
  debtId String
  debt   Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String           @id @default(uuid())
  type            ConversationType @default(PRIVATE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastMessageId   String?
  
  participants    User[]           @relation("ConversationParticipants")
  messages        Message[]

  @@index([updatedAt])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String       @db.Text
  attachments    String[]     @default([])
  createdAt      DateTime     @default(now())
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  seenBy         User[]       @relation("MessageSeenBy")

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model ExchangeOrder {
  id                    String            @id @default(uuid())
  userId                String
  fromCurrency          String
  toCurrency            String
  amount                Float
  exchangeRate          Float
  expectedReceiveAmount Float
  referenceCode         String            @unique
  senderName            String?
  status                ExchangeStatus    @default(pending)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id])
  proof                 PaymentProof?
  logs                  VerificationLog[]
}

model PaymentProof {
  id         String        @id @default(uuid())
  orderId    String        @unique
  imageUrl   String
  uploadedAt DateTime      @default(now())
  status     ProofStatus   @default(pending)
  order      ExchangeOrder @relation(fields: [orderId], references: [id])
}

model VerificationLog {
  id                String             @id @default(uuid())
  orderId           String
  checkedAmount     Float
  checkedSenderName String
  checkedReference  String
  result            VerificationResult
  createdAt         DateTime           @default(now())
  order             ExchangeOrder      @relation(fields: [orderId], references: [id])
}

model Sale {
  id              String      @id @default(uuid())
  userId          String
  customerId      String?     @db.Text
  customerName    String?     @db.Text
  customerPhone   String?     @db.Text
  customerType    String?     // retail, wholesale, repeat
  branchId        String?     // identifier for multi-branch
  status          SaleStatus  @default(COMPLETED)
  paymentMethod   String      @default("CASH")
  paymentStatus   String      @default("PAID")
  
  subtotal        Float
  tax             Float       @default(0)
  discount        Float       @default(0)
  totalAmount     Float
  amountPaid      Float
  balance         Float       @default(0)
  
  channel         String      @default("IN_STORE") @db.Text
  reference       String?     @db.Text
  notes           String?     @db.Text
  
  items           SaleItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  user            User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

model SaleItem {
  id              String   @id @default(uuid())
  saleId          String
  productId       String?     @db.Text
  productName     String      @db.Text
  quantity        Int
  unitPrice       Float
  discount        Float    @default(0)
  totalPrice      Float
  
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

enum SaleStatus {
  COMPLETED
  PENDING
  CANCELLED
  DRAFT
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum DebtType {
  RECEIVABLE
  PAYABLE
}

enum DebtStatus {
  PAID
  UNPAID
  OVERDUE
}

enum UserRole {
  USER
  MERCHANT
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  deviceInfo String?
  ipAddress  String?
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String
  actionType String   // LOGIN, TRANSACTION_CREATED, DEBT_UPDATED, PROFILE_UPDATED
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum ConversationType {
  PRIVATE
  GROUP
  SUPPORT
}

enum ExchangeStatus {
  pending
  proof_uploaded
  ready_for_confirmation
  under_review
  confirmed
  rejected
  completed
}

enum ProofStatus {
  pending
  verified
  rejected
}

enum VerificationResult {
  matched
  mismatch
}

model OfflineAction {
  id          String   @id @default(uuid())
  actionType  String   // create, update, delete
  entity      String   // transaction
  payload     Json
  status      String   @default("pending") // pending, synced, failed
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([status])
}
