generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  passcode       String?
  role           UserRole        @default(USER)
  age            Int?
  avatarUrl      String?
  bio            String?
  name           String?
  username       String?         @unique
  debts          Debt[]
  exchangeOrders ExchangeOrder[]
  products       Product[]
  transactions   Transaction[]
}

model Transaction {
  id        String          @id @default(uuid())
  amount    Float
  category  String
  date      DateTime        @default(now())
  note      String?
  userId    String
  type      TransactionType
  productId String?
  quantity  Int?            @default(1)
  product   Product?        @relation(fields: [productId], references: [id])
  user      User            @relation(fields: [userId], references: [id])
}

model Product {
  id           String        @id @default(uuid())
  name         String
  quantity     Int           @default(0)
  costPrice    Float
  sellingPrice Float
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Debt {
  id              String     @id @default(uuid())
  dueDate         DateTime
  createdAt       DateTime   @default(now())
  name            String
  remainingAmount Float
  totalAmount     Float
  type            DebtType
  updatedAt       DateTime   @updatedAt
  userId          String
  status          DebtStatus @default(UNPAID)
  phone           String?
  user            User       @relation(fields: [userId], references: [id])
  payments        Payment[]
}

model Payment {
  id     String   @id @default(uuid())
  amount Float
  date   DateTime @default(now())
  debtId String
  debt   Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String    @id @default(uuid())
  merchantId      String
  participantName String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ExchangeOrder {
  id                    String            @id @default(uuid())
  userId                String
  fromCurrency          String
  toCurrency            String
  amount                Float
  exchangeRate          Float
  expectedReceiveAmount Float
  referenceCode         String            @unique
  senderName            String?
  status                ExchangeStatus    @default(pending)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id])
  proof                 PaymentProof?
  logs                  VerificationLog[]
}

model PaymentProof {
  id         String        @id @default(uuid())
  orderId    String        @unique
  imageUrl   String
  uploadedAt DateTime      @default(now())
  status     ProofStatus   @default(pending)
  order      ExchangeOrder @relation(fields: [orderId], references: [id])
}

model VerificationLog {
  id                String             @id @default(uuid())
  orderId           String
  checkedAmount     Float
  checkedSenderName String
  checkedReference  String
  result            VerificationResult
  createdAt         DateTime           @default(now())
  order             ExchangeOrder      @relation(fields: [orderId], references: [id])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum DebtType {
  RECEIVABLE
  PAYABLE
}

enum DebtStatus {
  PAID
  UNPAID
  OVERDUE
}

enum UserRole {
  USER
  ADMIN
}

enum ExchangeStatus {
  pending
  proof_uploaded
  ready_for_confirmation
  under_review
  confirmed
  rejected
  completed
}

enum ProofStatus {
  pending
  verified
  rejected
}

enum VerificationResult {
  matched
  mismatch
}
